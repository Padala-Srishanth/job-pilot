{
  "manifest_version": 3,
  "name": "JobPilot - Smart Job Apply",
  "version": "1.0.0",
  "description": "Save and apply to jobs directly from LinkedIn, Indeed, Naukri, and more with one click.",
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://in.indeed.com/*",
    "https://www.indeed.com/*",
    "https://www.naukri.com/*",
    "https://internshala.com/*",
    "https://www.glassdoor.co.in/*",
    "https://www.glassdoor.com/*",
    "https://www.foundit.in/*",
    "https://www.timesjobs.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://in.indeed.com/*",
        "https://www.indeed.com/*",
        "https://www.naukri.com/*",
        "https://internshala.com/*",
        "https://www.glassdoor.co.in/*",
        "https://www.glassdoor.com/*",
        "https://www.foundit.in/*",
        "https://www.timesjobs.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
